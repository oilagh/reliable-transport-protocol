#!/usr/bin/env -S python3 -u

import socket, time, json, sys, hashlib

CHUNK_SIZE = 1000

def checksum(data):
    return hashlib.md5(data.encode()).hexdigest()

class Sender:
    def __init__(self, host, port):
        self.sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        self.sock.settimeout(0.05)
        self.addr = (host, int(port))

    def send(self, msg):
        self.sock.sendto(json.dumps(msg).encode(), self.addr)

    def recv(self):
        try:
            data, _ = self.sock.recvfrom(65535)
            return json.loads(data.decode())
        except:
            return None

    def run(self):
        data = sys.stdin.read()

        chunks = []
        i = 0
        while i < len(data):
            chunks.append(data[i:i+CHUNK_SIZE])
            i += CHUNK_SIZE

        send_buffer = {}
        send_time = {}

        base = 0
        next_seq = 0
        window_size = 5   # slightly bigger than before
        timeout = 0.4     # key: better for jitter

        total_data = len(data)

        while True:

            # Send within window
            while (next_seq - base) < window_size * CHUNK_SIZE and next_seq < total_data:
                chunk_index = next_seq // CHUNK_SIZE
                payload = chunks[chunk_index]

                pkt = {
                    "type": "msg",
                    "seq": next_seq,
                    "data": payload,
                    "checksum": checksum(payload)
                }

                self.send(pkt)
                send_buffer[next_seq] = pkt
                send_time[next_seq] = time.time()

                next_seq += len(payload)

            # Receive ACK
            msg = self.recv()
            if msg and msg.get("type") == "ack":
                if "seq" in msg and "checksum" in msg:
                    ack = msg["seq"]

                    # validate ACK
                    if checksum(str(ack)) == msg["checksum"]:
                        if base <= ack <= next_seq:
                            # remove acknowledged packets
                            for s in list(send_buffer):
                                if s < ack:
                                    del send_buffer[s]
                                    del send_time[s]

                            base = ack

            # Retransmit ALL timed-out packets (IMPORTANT)
            now = time.time()
            for s in list(send_buffer):
                if now - send_time[s] > timeout:
                    self.send(send_buffer[s])
                    send_time[s] = now

            if base >= total_data:
                break


if __name__ == "__main__":
    host = sys.argv[1]
    port = sys.argv[2]
    Sender(host, port).run()
