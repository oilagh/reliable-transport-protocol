#!/usr/bin/env -S python3 -u

import socket
import time
import json
import sys
import hashlib

CHUNK_SIZE = 1000

def checksum(data):
    return hashlib.md5(data.encode()).hexdigest()


class Sender:
    def __init__(self, host, port):
        self.sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        self.sock.settimeout(0.01)
        self.addr = (host, int(port))

    def send(self, msg):
        self.sock.sendto(json.dumps(msg).encode("utf-8"), self.addr)

    def recv(self):
        try:
            data, _ = self.sock.recvfrom(65535)
            return json.loads(data.decode("utf-8"))
        except Exception:
            return None

    def run(self):
        data = sys.stdin.read()
        total_data = len(data)

        if total_data == 0:
            return

        chunks = []
        i = 0
        while i < total_data:
            chunks.append(data[i:i + CHUNK_SIZE])
            i += CHUNK_SIZE

        send_buffer = {}   # seq -> packet
        send_time = {}     # seq -> last send time

        base = 0
        next_seq = 0

        window_size = 4
        max_window = 20
        timeout = 0.20

        last_ack = -1
        dup_ack_count = 0

        while base < total_data:
            # Fill available window
            while next_seq < total_data and (next_seq - base) < window_size * CHUNK_SIZE:
                chunk_index = next_seq // CHUNK_SIZE
                payload = chunks[chunk_index]

                pkt = {
                    "type": "msg",
                    "seq": next_seq,
                    "data": payload,
                    "checksum": checksum(payload)
                }

                self.send(pkt)
                send_buffer[next_seq] = pkt
                send_time[next_seq] = time.time()
                next_seq += len(payload)

            # Drain ACKs currently available
            while True:
                msg = self.recv()
                if msg is None:
                    break

                if msg.get("type") != "ack":
                    continue
                if "seq" not in msg or "checksum" not in msg:
                    continue

                ack = msg["seq"]

                if not isinstance(ack, int):
                    continue
                if checksum(str(ack)) != msg["checksum"]:
                    continue
                if ack < base or ack > next_seq:
                    continue

                if ack > base:
                    # new cumulative ACK
                    for s in list(send_buffer.keys()):
                        if s < ack:
                            del send_buffer[s]
                            del send_time[s]

                    base = ack
                    dup_ack_count = 0
                    last_ack = ack

                    # additive increase
                    if window_size < max_window:
                        window_size += 1

                elif ack == base:
                    # duplicate ACK
                    if ack == last_ack:
                        dup_ack_count += 1
                    else:
                        last_ack = ack
                        dup_ack_count = 1

                    if dup_ack_count >= 3 and base in send_buffer:
                        self.send(send_buffer[base])
                        send_time[base] = time.time()
                        window_size = max(1, window_size // 2)
                        dup_ack_count = 0

            # retransmit timed-out oldest unacked packet
            if base in send_buffer:
                now = time.time()
                if now - send_time[base] >= timeout:
                    self.send(send_buffer[base])
                    send_time[base] = now
                    window_size = max(1, window_size // 2)
                    dup_ack_count = 0


if __name__ == "__main__":
    host = sys.argv[1]
    port = sys.argv[2]
    Sender(host, port).run()
