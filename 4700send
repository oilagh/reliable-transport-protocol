#!/usr/bin/env -S python3 -u

import socket
import time
import json
import sys
import hashlib

CHUNK_SIZE = 1000

def checksum(data):
    return hashlib.md5(data.encode()).hexdigest()


class Sender:
    def __init__(self, host, port):
        self.sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        self.sock.settimeout(0.05)
        self.addr = (host, int(port))

    def send(self, msg):
        self.sock.sendto(json.dumps(msg).encode("utf-8"), self.addr)

    def recv(self):
        try:
            data, _ = self.sock.recvfrom(65535)
            return json.loads(data.decode("utf-8"))
        except Exception:
            return None

    def run(self):
        data = sys.stdin.read()
        total_data = len(data)

        if total_data == 0:
            return

        chunks = []
        i = 0
        while i < total_data:
            chunks.append(data[i:i + CHUNK_SIZE])
            i += CHUNK_SIZE

        send_buffer = {}   # seq -> packet
        send_time = {}     # seq -> last send time

        base = 0
        next_seq = 0

        window_size = 4
        timeout = 0.3

        # for gentler additive increase
        ack_counter = 0

        while base < total_data:
            # Fill window
            in_flight = next_seq - base
            while in_flight < window_size * CHUNK_SIZE and next_seq < total_data:
                chunk_index = next_seq // CHUNK_SIZE
                payload = chunks[chunk_index]

                pkt = {
                    "type": "msg",
                    "seq": next_seq,
                    "data": payload,
                    "checksum": checksum(payload)
                }

                self.send(pkt)
                send_buffer[next_seq] = pkt
                send_time[next_seq] = time.time()

                next_seq += len(payload)
                in_flight = next_seq - base

            # Process one ACK if available
            msg = self.recv()
            if isinstance(msg, dict) and msg.get("type") == "ack":
                if "seq" in msg and "checksum" in msg:
                    ack = msg["seq"]
                    ack_checksum = msg["checksum"]

                    if isinstance(ack, int) and isinstance(ack_checksum, str):
                        # validate ACK checksum
                        if checksum(str(ack)) == ack_checksum:
                            # only accept cumulative ACKs within current sent range
                            if base <= ack <= next_seq:
                                if ack > base:
                                    old_base = base
                                    base = ack

                                    # remove all acknowledged packets
                                    for s in list(send_buffer.keys()):
                                        if s < ack:
                                            del send_buffer[s]
                                            del send_time[s]

                                    # additive increase: much slower
                                    ack_counter += 1
                                    if ack_counter >= window_size:
                                        window_size += 1
                                        ack_counter = 0

            # Timeout: retransmit oldest unacked only
            if base < next_seq and base in send_time:
                now = time.time()
                if now - send_time[base] > timeout:
                    self.send(send_buffer[base])
                    send_time[base] = now

                    # multiplicative decrease
                    window_size = max(1, window_size // 2)
                    ack_counter = 0

            # prevent runaway window growth
            window_size = min(window_size, 20)


if __name__ == "__main__":
    host = sys.argv[1]
    port = sys.argv[2]
    Sender(host, port).run()