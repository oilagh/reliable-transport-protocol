#!/usr/bin/env -S python3 -u

import socket
import time
import json
import sys
import hashlib

CHUNK_SIZE = 1000

def checksum(data):
    return hashlib.md5(data.encode()).hexdigest()


class Sender:
    def __init__(self, host, port):
        self.sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        self.sock.settimeout(0.02)
        self.addr = (host, int(port))

    def send(self, msg):
        self.sock.sendto(json.dumps(msg).encode("utf-8"), self.addr)

    def recv(self):
        try:
            data, _ = self.sock.recvfrom(65535)
            return json.loads(data.decode("utf-8"))
        except Exception:
            return None

    def run(self):
        data = sys.stdin.read()
        total_data = len(data)

        if total_data == 0:
            return

        chunks = []
        i = 0
        while i < total_data:
            chunks.append(data[i:i + CHUNK_SIZE])
            i += CHUNK_SIZE

        send_buffer = {}
        send_time = {}

        base = 0
        next_seq = 0

        window_size = 4
        timeout = 0.30

        last_ack = -1
        dup_ack_count = 0
        ack_progress = 0

        while base < total_data:
            # Fill window
            while next_seq < total_data and (next_seq - base) < window_size * CHUNK_SIZE:
                chunk_index = next_seq // CHUNK_SIZE
                payload = chunks[chunk_index]

                pkt = {
                    "type": "msg",
                    "seq": next_seq,
                    "data": payload,
                    "checksum": checksum(payload)
                }

                self.send(pkt)
                send_buffer[next_seq] = pkt
                send_time[next_seq] = time.time()

                next_seq += len(payload)

            # Drain queued ACKs
            while True:
                msg = self.recv()
                if msg is None:
                    break

                if msg.get("type") != "ack":
                    continue
                if "seq" not in msg or "checksum" not in msg:
                    continue

                ack = msg["seq"]

                if checksum(str(ack)) != msg["checksum"]:
                    continue

                if ack < base or ack > next_seq:
                    continue

                if ack > base:
                    newly_acked = ack - base
                    base = ack

                    for s in list(send_buffer.keys()):
                        if s < ack:
                            del send_buffer[s]
                            del send_time[s]

                    # reset dup ack state
                    last_ack = ack
                    dup_ack_count = 0

                    # slower additive increase
                    ack_progress += newly_acked
                    if ack_progress >= window_size * CHUNK_SIZE:
                        window_size += 1
                        ack_progress = 0

                elif ack == base:
                    if ack == last_ack:
                        dup_ack_count += 1
                    else:
                        last_ack = ack
                        dup_ack_count = 1

                    # fast retransmit
                    if dup_ack_count >= 3 and base in send_buffer:
                        self.send(send_buffer[base])
                        send_time[base] = time.time()
                        window_size = max(2, window_size - 1)
                        dup_ack_count = 0

            # timeout retransmit oldest unacked only
            if base < next_seq and base in send_time:
                now = time.time()
                if now - send_time[base] > timeout:
                    self.send(send_buffer[base])
                    send_time[base] = now
                    window_size = max(1, window_size // 2)
                    ack_progress = 0
                    dup_ack_count = 0

            # tighter cap for low-bandwidth stability
            window_size = min(window_size, 12)


if __name__ == "__main__":
    host = sys.argv[1]
    port = sys.argv[2]
    Sender(host, port).run()
