#!/usr/bin/env -S python3 -u

import socket
import time
import json
import sys
import hashlib

CHUNK_SIZE = 1000

def checksum(data):
    return hashlib.md5(data.encode()).hexdigest()

class Sender:
    def __init__(self, host, port):
        self.sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        self.sock.settimeout(0.1)
        self.addr = (host, int(port))

    def send(self, msg):
        self.sock.sendto(json.dumps(msg).encode(), self.addr)

    def recv(self):
        try:
            data, _ = self.sock.recvfrom(65535)
            return json.loads(data.decode())
        except:
            return None

    def run(self):
        data = sys.stdin.read()

        chunks = []
        i = 0
        while i < len(data):
            chunks.append(data[i:i + CHUNK_SIZE])
            i += CHUNK_SIZE

        send_buffer = {}   # seq -> packet
        send_time = {}     # seq -> last send time

        base = 0
        next_seq = 0
        window_size = 4
        timeout = 1.0
        total_data = len(data)

        while True:
            # Send packets while window has room
            while (next_seq - base) < window_size * CHUNK_SIZE and next_seq < total_data:
                chunk_index = next_seq // CHUNK_SIZE
                payload = chunks[chunk_index]

                pkt = {
                    "type": "msg",
                    "seq": next_seq,
                    "data": payload,
                    "checksum": checksum(payload)
                }

                self.send(pkt)
                send_buffer[next_seq] = pkt
                send_time[next_seq] = time.time()

                next_seq += len(payload)

            # Receive and validate ACK
            msg = self.recv()
            if msg is not None:
                if msg.get("type") == "ack" and "seq" in msg and "checksum" in msg:
                    ack = msg["seq"]

                    # Reject corrupted ACKs
                    if checksum(str(ack)) == msg["checksum"]:
                        # Reject impossible / stale / future ACKs
                        if base <= ack <= next_seq:
                            if ack > base:
                                # Remove acknowledged packets
                                for s in list(send_buffer):
                                    if s < ack:
                                        del send_buffer[s]
                                        del send_time[s]

                                # Congestion control: additive increase
                                newly_acked = ack - base
                                base = ack

                                # Increase slowly to avoid overfilling low-bandwidth links
                                if newly_acked > 0:
                                    window_size += 1

            # Timeout-based retransmission + congestion backoff
            now = time.time()
            timeout_happened = False

            for s in list(send_buffer):
                if now - send_time[s] > timeout:
                    self.send(send_buffer[s])
                    send_time[s] = now
                    timeout_happened = True

            if timeout_happened:
                window_size = max(1, window_size // 2)

            # Prevent runaway growth
            window_size = min(window_size, 50)

            if base >= total_data:
                break


if __name__ == "__main__":
    host = sys.argv[1]
    port = sys.argv[2]
    Sender(host, port).run()
