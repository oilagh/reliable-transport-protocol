#!/usr/bin/env -S python3 -u

import socket
import time
import json
import sys
import hashlib

CHUNK_SIZE = 1000


def checksum(data):
    return hashlib.md5(data.encode()).hexdigest()


class Sender:
    def __init__(self, host, port):
        self.sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        self.sock.settimeout(0.05)
        self.addr = (host, int(port))

    def send(self, msg):
        self.sock.sendto(json.dumps(msg).encode("utf-8"), self.addr)

    def recv(self):
        try:
            data, _ = self.sock.recvfrom(65535)
            return json.loads(data.decode("utf-8"))
        except Exception:
            return None

    def run(self):
        data = sys.stdin.read()

        chunks = []
        i = 0
        while i < len(data):
            chunks.append(data[i:i + CHUNK_SIZE])
            i += CHUNK_SIZE

        total_data = len(data)

        # seq -> packet / send time
        send_buffer = {}
        send_time = {}

        base = 0
        next_seq = 0

        # TCP Tahoe style congestion control
        cwnd = 1.0           # congestion window in packets
        ssthresh = 8.0
        timeout = 0.35

        while True:
            window_packets = max(1, int(cwnd))

            # fill window
            while len(send_buffer) < window_packets and next_seq < total_data:
                chunk_index = next_seq // CHUNK_SIZE
                payload = chunks[chunk_index]

                pkt = {
                    "type": "msg",
                    "seq": next_seq,
                    "data": payload,
                    "checksum": checksum(payload)
                }

                self.send(pkt)
                send_buffer[next_seq] = pkt
                send_time[next_seq] = time.time()
                next_seq += len(payload)

            # process at most one ACK per loop
            msg = self.recv()
            if isinstance(msg, dict):
                if (
                    msg.get("type") == "ack"
                    and "seq" in msg
                    and "checksum" in msg
                    and isinstance(msg["seq"], int)
                    and isinstance(msg["checksum"], str)
                ):
                    ack = msg["seq"]

                    # valid ACK checksum?
                    if checksum(str(ack)) == msg["checksum"]:
                        # ACK must be in sane range
                        if base <= ack <= next_seq:
                            if ack > base:
                                # remove all acknowledged packets
                                for s in list(send_buffer.keys()):
                                    if s < ack:
                                        del send_buffer[s]
                                        del send_time[s]

                                base = ack

                                # slow start / congestion avoidance
                                if cwnd < ssthresh:
                                    cwnd += 1.0
                                else:
                                    cwnd += 1.0 / cwnd

            # done?
            if base >= total_data:
                break

            # timeout: retransmit oldest unacked only
            if send_buffer:
                oldest_seq = min(send_buffer.keys())
                if time.time() - send_time[oldest_seq] >= timeout:
                    self.send(send_buffer[oldest_seq])
                    send_time[oldest_seq] = time.time()

                    # Tahoe backoff
                    ssthresh = max(2.0, cwnd / 2.0)
                    cwnd = 1.0


if __name__ == "__main__":
    host = sys.argv[1]
    port = sys.argv[2]
    Sender(host, port).run()
